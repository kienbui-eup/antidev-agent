#!/usr/bin/env bash
# antidev-config — read/write ~/.antidev/config.yaml
#
# Usage:
#   antidev-config get <key>          — read a config value
#   antidev-config set <key> <value>  — write a config value
#   antidev-config list               — show all config
#
# Env overrides (for testing):
#   ANTIDEV_STATE_DIR  — override ~/.antidev state directory
set -euo pipefail

STATE_DIR="${ANTIDEV_STATE_DIR:-$HOME/.antidev}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: antidev-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: antidev-config set <key> <value>}"
    VALUE="${3:?Usage: antidev-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      sed -i '' "s/^${KEY}:.*/${KEY}: ${VALUE}/" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: antidev-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
