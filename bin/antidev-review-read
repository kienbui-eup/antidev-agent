#!/usr/bin/env bash
# antidev-review-read — read review log and config for dashboard
# Usage: antidev-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval $("$SCRIPT_DIR/antidev-slug" 2>/dev/null)
ANTIDEV_HOME="${ANTIDEV_HOME:-$HOME/.antidev}"
cat "$ANTIDEV_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/antidev-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
